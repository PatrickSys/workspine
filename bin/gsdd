#!/usr/bin/env node

const fs = require('fs');
const path = require('path');
const { execSync } = require('child_process');
const os = require('os');
const readline = require('readline');

const args = process.argv.slice(2);
const command = args[0];

// --- Governance & Config ---

function loadConfig() {
    const configPath = 'gsdd.json';
    if (fs.existsSync(configPath)) {
        try {
            return JSON.parse(fs.readFileSync(configPath, 'utf8'));
        } catch (e) {
            console.warn('\x1b[33mWarning: Could not parse gsdd.json. Using defaults.\x1b[0m');
        }
    }
    return {
        version: "1.0",
        commit_docs: false,
        workflow: {
            research: true,
            plan_check: true,
            verifier: true
        }
    };
}

function checkBranch() {
    try {
        const branch = execSync('git branch --show-current', { stdio: 'pipe' }).toString().trim();
        if (branch === 'main' || branch === 'master') {
            console.error('\x1b[31mGovernance Error: You are on the protected branch "%s".\x1b[0m', branch);
            console.error('Action Required: Please create a feature branch before starting work.');
            console.error('  git checkout -b feature/your-goal');
            process.exit(1);
        }
    } catch (e) {
        // Strict governance requires git
        console.error('\x1b[31mGovernance Error: Not a git repository or git error.\x1b[0m');
        console.error('Action Required: Initialize a git repository to track work.');
        process.exit(1);
    }
}

function init() {
    // 1. Create .planning directory (private scratchpad)
    const planningDir = '.planning';
    if (!fs.existsSync(planningDir)) {
        fs.mkdirSync(planningDir);
    }

    // 2. Create gsdd.json (versioned config)
    const configPath = 'gsdd.json';
    if (!fs.existsSync(configPath)) {
        const config = {
            version: "1.0",
            commit_docs: false,
            workflow: {
                research: true,
                plan_check: true,
                verifier: true
            }
        };
        fs.writeFileSync(configPath, JSON.stringify(config, null, 2));
        console.log('\x1b[32mInitialized GSD Distilled config at gsdd.json\x1b[0m');
        console.log('Governance: commit_docs set to false (no planning artifacts in repo).');
    } else {
        // Ensure config is loaded to check settings
        const config = loadConfig();
        if (config.commit_docs === false) {
             console.log('Governance: commit_docs is false.');
        }
    }

    // 3. Update .gitignore (ensure .planning/ is ignored based on config)
    const config = loadConfig();
    if (config.commit_docs === false) {
        if (fs.existsSync('.gitignore')) {
            const gitignore = fs.readFileSync('.gitignore', 'utf8');
            if (!gitignore.includes('.planning/')) {
                fs.appendFileSync('.gitignore', '\n.planning/\n');
                console.log('Added .planning/ to .gitignore (governance enforcement)');
            }
        } else {
            fs.writeFileSync('.gitignore', '.planning/\n');
            console.log('Created .gitignore with .planning/ (governance enforcement)');
        }
    }
}

// --- Agent Adapters ---

function getWorkflowContent(workflowName) {
    // Load local workflow file content directly
    const workflowPath = path.join(__dirname, '..', 'distilled', 'workflows', workflowName);

    if (fs.existsSync(workflowPath)) {
        return fs.readFileSync(workflowPath, 'utf8');
    }

    // Fallback content if file not found
    if (workflowName === 'spec.md') {
        return `
# Spec Workflow
1. Research goal if needed.
2. Create .planning/SPEC.md with tasks and must-haves.
`;
    }
    if (workflowName === 'execute.md') {
        return `
# Execute Workflow
1. Read .planning/SPEC.md.
2. Execute tasks atomically.
3. Create .planning/SUMMARY.md.
`;
    }
    if (workflowName === 'verify.md') {
        return `
# Verify Workflow
1. Read .planning/SPEC.md must-haves.
2. Verify implementation.
3. Create .planning/VERIFICATION.md.
`;
    }
    return '';
}

function formatOutput(agentType, step, content, goal = '') {
    const separator = '\n\x1b[36m==============================================\x1b[0m\n';
    const header = '\n\x1b[36m=== Copy and paste this into your AI agent ===\x1b[0m\n';

    let output = '';

    if (agentType === 'claude') {
        // Claude Code optimized: Use direct instructions
        output = `
${header}
Request: ${step}
Goal: ${goal}

${content}
${separator}
`;
    } else if (agentType === 'gemini') {
        // Gemini optimized: Clear steps, plain text
        output = `
${header}
Task: ${step}
Goal: "${goal}"

Instructions:
${content}
${separator}
`;
    } else {
        // Generic / Agent-Agnostic: Standard Work Order
        output = `
${header}
WORK ORDER: ${step}
GOAL: "${goal}"

${content}
${separator}
`;
    }

    console.log(output);
}

// --- Commands ---

function spec(args) {
    checkBranch();
    init();

    const isClaude = args.includes('--claude');
    const isGemini = args.includes('--gemini');
    const agentType = isClaude ? 'claude' : (isGemini ? 'gemini' : 'generic');

    const goalArgs = args.filter(a => !a.startsWith('--'));
    const goal = goalArgs.join(' ');

    if (!goal) {
        console.error('Error: Please provide a goal.');
        process.exit(1);
    }

    const content = getWorkflowContent('spec.md');
    formatOutput(agentType, 'SPECIFICATION', content, goal);
}

function execute(args) {
    checkBranch();
    if (!fs.existsSync('.planning/SPEC.md')) {
        console.error('Error: .planning/SPEC.md not found. Run "gsdd spec <goal>" first.');
        process.exit(1);
    }

    const isClaude = args.includes('--claude');
    const isGemini = args.includes('--gemini');
    const agentType = isClaude ? 'claude' : (isGemini ? 'gemini' : 'generic');

    const content = getWorkflowContent('execute.md');
    // For execution, the goal is implicitly the spec
    formatOutput(agentType, 'EXECUTION', content, "Implement SPEC.md");
}

function verify(args) {
    checkBranch();

    const isClaude = args.includes('--claude');
    const isGemini = args.includes('--gemini');
    const agentType = isClaude ? 'claude' : (isGemini ? 'gemini' : 'generic');

    const content = getWorkflowContent('verify.md');
    formatOutput(agentType, 'VERIFICATION', content, "Verify SPEC.md Implementation");
}

function doCommand(args) {
    checkBranch();
    init();

    const isClaude = args.includes('--claude');
    const isGemini = args.includes('--gemini');
    const agentType = isClaude ? 'claude' : (isGemini ? 'gemini' : 'generic');

    const goalArgs = args.filter(a => !a.startsWith('--'));
    const goal = goalArgs.join(' ');

    if (!goal) {
        console.error('Error: Please provide a goal.');
        process.exit(1);
    }

    // Safety check: is the goal risky? (Heuristic: keywords or length)
    const isRisky = goal.toLowerCase().includes('delete') ||
                    goal.toLowerCase().includes('remove') ||
                    goal.toLowerCase().includes('refactor') ||
                    goal.toLowerCase().includes('destroy') ||
                    goal.split(' ').length > 15;

    if (isRisky) {
        console.log('\x1b[33mRisk Assessment: This goal seems complex or potentially destructive.\x1b[0m');
        // Simple prompt, non-blocking for CLI simplicity, but warns user
        console.log('Please ensure you have reviewed the goal carefully.');
    }

    // Combine workflows for "Do" command
    // This allows the agent to chain them or see the whole picture
    const specContent = getWorkflowContent('spec.md');
    const execContent = getWorkflowContent('execute.md');
    const verifyContent = getWorkflowContent('verify.md');

    const combinedContent = `
PHASE 1: SPECIFICATION
${specContent}

PHASE 2: EXECUTION
(Proceed after Phase 1 is complete and approved)
${execContent}

PHASE 3: VERIFICATION
(Proceed after Phase 2 is complete)
${verifyContent}
`;

    formatOutput(agentType, 'COMPLETE WORKFLOW', combinedContent, goal);
}

function help() {
    console.log(`
GSD Distilled (gsdd) - A governed, simplified workflow for AI agents.

Usage:
  gsdd <command> [options]

Commands:
  init      Initialize project (config, gitignore).
  spec      Generate instructions to Spec/Plan a goal.
  execute   Generate instructions to Execute the plan.
  verify    Generate instructions to Verify the work.
  do        Generate instructions to do it all in one go (Happy Path).
  help      Show this help.

Options:
  --claude  Output optimized for Claude Code.
  --gemini  Output optimized for Gemini CLI.

Governance:
  - Enforces feature branches (blocks main/master).
  - Defaults to private planning artifacts (.planning/ in .gitignore).
`);
}

switch (command) {
    case 'init':
        init();
        break;
    case 'spec':
        spec(args.slice(1));
        break;
    case 'execute':
        execute(args.slice(1));
        break;
    case 'verify':
        verify(args.slice(1));
        break;
    case 'do':
        doCommand(args.slice(1));
        break;
    case 'help':
    case '--help':
    case '-h':
    default:
        help();
        break;
}
